<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>채널별 상세 리포트 · {{ date }}</title>
<style>
  :root{
    --bg:#f6f7f9; --card:#ffffff; --ink:#20242c; --muted:#6b7280; --line:#e5e8ef;
    --accent:#2f5fe0; --up:#e0342b; --down:#1666d6;
    --pre:#f59e0b; --during:#22c55e; --post:#a855f7;
    --chip:#eef2fb; --shadow:0 1px 3px rgba(20,30,60,.07);
  }
  @media (prefers-color-scheme: dark){
    :root{ --bg:#0e1117; --card:#171b23; --ink:#e6e9f0; --muted:#9aa4b2; --line:#252b36;
      --accent:#5b86f5; --up:#ff5b52; --down:#4d9bff; --chip:#1e2530; --shadow:0 1px 3px rgba(0,0,0,.4);}
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--ink);
    font-family:'Segoe UI','Malgun Gothic',system-ui,sans-serif;font-size:15px;line-height:1.55}
  .wrap{max-width:820px;margin:0 auto;padding:22px 20px 70px}
  a{color:var(--accent);text-decoration:none} a:hover{text-decoration:underline}

  header.top{margin-bottom:18px}
  header.top h1{font-size:21px;margin:0 0 4px}
  .sub{color:var(--muted);font-size:13px}
  .nav{margin-top:8px;font-size:13px}

  /* 목차 */
  .toc{background:var(--card);border:1px solid var(--line);border-radius:12px;
    box-shadow:var(--shadow);padding:12px 16px;margin-bottom:26px}
  .toc h2{font-size:13px;margin:0 0 8px;color:var(--muted);letter-spacing:.4px}
  .toc ol{margin:0;padding-left:20px} .toc li{margin:4px 0}
  .toc .cnt{color:var(--muted);font-size:12px}

  /* 배지 */
  .badge{display:inline-block;font-size:11.5px;font-weight:600;padding:2px 9px;
    border-radius:999px;color:#fff;vertical-align:middle}
  .b-pre{background:var(--pre)} .b-during{background:var(--during)} .b-post{background:var(--post)}
  .badge.ghost{background:transparent;border:1px solid var(--line);color:var(--muted)}

  /* 채널 섹션 */
  section.ch{margin-bottom:38px}
  .chhead{position:sticky;top:0;background:var(--bg);padding:10px 0 8px;
    border-bottom:2px solid var(--accent);margin-bottom:16px;z-index:5}
  .chhead .nm{font-size:19px;font-weight:800;letter-spacing:-.2px}
  .chhead .meta{color:var(--muted);font-size:12.5px;margin-top:2px}
  .chhead .badges{margin-top:6px;display:flex;gap:5px;flex-wrap:wrap}

  /* 영상 아티클 */
  article.vid{background:var(--card);border:1px solid var(--line);border-radius:14px;
    box-shadow:var(--shadow);padding:20px 24px;margin-bottom:18px}
  article.vid .vhead{display:flex;align-items:flex-start;gap:10px;
    justify-content:space-between;flex-wrap:wrap;margin-bottom:4px}
  article.vid h3{font-size:17px;margin:0;line-height:1.4;flex:1;min-width:60%}
  article.vid .when{color:var(--muted);font-size:12.5px;margin-bottom:12px}
  .prose p{margin:0 0 13px;font-size:15.5px;line-height:1.85;
    word-break:keep-all;overflow-wrap:break-word}
  .prose p:last-child{margin-bottom:0}

  .kv{margin-top:16px;padding-top:14px;border-top:1px dashed var(--line)}
  .kv h4{font-size:12.5px;color:var(--muted);margin:0 0 6px;letter-spacing:.3px}
  .kv ul{margin:0 0 12px;padding-left:18px} .kv li{margin:3px 0;font-size:13.5px}
  .fore{font-size:13.5px;margin-bottom:12px}
  .fore .dir{font-weight:700}
  .tags{display:flex;flex-wrap:wrap;gap:5px}
  .tag{font-size:12px;padding:2px 9px;border-radius:7px;background:var(--chip);
    border:1px solid var(--line)}
  .tag.p{color:var(--up)} .tag.n{color:var(--down)}
  .up{color:var(--up)} .down{color:var(--down)}

  footer{margin-top:30px;color:var(--muted);font-size:11.5px;text-align:center}
  .empty{color:var(--muted);text-align:center;padding:40px 0}
</style>
</head>
<body>
<div class="wrap">

  <header class="top">
    <h1>📰 채널별 상세 리포트</h1>
    <div class="sub">{{ date }} · 총 {{ total_videos }}개 영상 · 채널 {{ channels|length }}곳</div>
    <div class="nav">← <a href="dashboard_{{ date }}.html">종합 대시보드로 돌아가기</a></div>
  </header>

  {% if channels %}
  <!-- 목차 -->
  <nav class="toc">
    <h2>목차</h2>
    <ol>
      {% for ch in channels %}
      <li>
        <a href="#ch-{{ loop.index }}">{{ ch.name }}</a>
        <span class="cnt">— {{ ch.count }}개
          {% for b in ch.buckets %}<span class="badge b-{{ b }}">{{ b|blabel }}</span>{% endfor %}
        </span>
      </li>
      {% endfor %}
    </ol>
  </nav>

  {% for ch in channels %}
  <section class="ch" id="ch-{{ loop.index }}">
    <div class="chhead">
      <div class="nm">📺 {{ ch.name }}</div>
      <div class="meta">당일 업로드 {{ ch.count }}개</div>
      <div class="badges">
        {% for b in ch.buckets %}<span class="badge b-{{ b }}">{{ b|blabel }}</span>{% endfor %}
      </div>
    </div>

    {% for v in ch.videos %}
    <article class="vid">
      <div class="vhead">
        <h3><a href="{{ v.url }}" target="_blank">{{ v.title }}</a></h3>
        <span class="badge b-{{ v.bucket }}">{{ v.bucket|blabel }}</span>
      </div>
      <div class="when">
        {% if v.upload_ts %}업로드 {{ v.upload_ts[11:16] }} · {% endif %}
        {% if v.duration %}{{ (v.duration//60) }}분 · {% endif %}
        {% if v.from_subtitle %}자막 기반{% else %}<span class="badge ghost">자막없음·제목기반</span>{% endif %}
      </div>

      <div class="prose">
        {% set paras = (v.상세요약 or '')|paras %}
        {% if paras %}
          {% for p in paras %}<p>{{ p }}</p>{% endfor %}
        {% else %}
          {% for s in v.핵심요약 %}<p>{{ s }}</p>{% endfor %}
        {% endif %}
      </div>

      <div class="kv">
        {% if v.핵심요약 %}
        <h4>핵심 포인트</h4>
        <ul>{% for s in v.핵심요약 %}<li>{{ s }}</li>{% endfor %}</ul>
        {% endif %}

        {% if v.시장전망 %}
        {% set dir = v.시장전망.방향 %}
        <div class="fore">📊 시장 전망:
          <span class="dir {{ 'up' if dir=='강세' else ('down' if dir=='약세' else '') }}">{{ dir }}</span>
          {% if v.시장전망.근거 %}— {{ v.시장전망.근거 }}{% endif %}
        </div>
        {% endif %}

        {% if v.언급종목 %}
        <h4>언급 종목</h4>
        <div class="tags">
          {% for m in v.언급종목 %}
          <span class="tag {{ 'p' if m.방향성=='긍정' else ('n' if m.방향성=='부정' else '') }}">
            {{ m.name }}{% if m.방향성 %} · {{ m.방향성 }}{% endif %}</span>
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </article>
    {% endfor %}
  </section>
  {% endfor %}

  {% else %}
  <div class="empty">당일 업로드된 영상이 없습니다.</div>
  {% endif %}

  <footer>자동 생성 · 채널별 상세 리포트 · {{ date }}</footer>
</div>
</body>
</html>
