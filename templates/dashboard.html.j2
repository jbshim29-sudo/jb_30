<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>경제 유튜브 종합 대시보드 · {{ date }}</title>
<style>
  :root{
    --bg:#f4f6fa; --card:#ffffff; --ink:#1a1d24; --muted:#6b7280;
    --line:#e5e8ef; --accent:#2f5fe0; --up:#e0342b; --down:#1666d6; --flat:#6b7280;
    --chip:#eef2fb; --shadow:0 1px 3px rgba(20,30,60,.08);
  }
  @media (prefers-color-scheme: dark){
    :root{ --bg:#0e1117; --card:#171b23; --ink:#e6e9f0; --muted:#9aa4b2;
      --line:#252b36; --accent:#5b86f5; --up:#ff5b52; --down:#4d9bff; --flat:#9aa4b2;
      --chip:#1e2530; --shadow:0 1px 3px rgba(0,0,0,.4);}
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--ink);
    font-family:'Segoe UI','Malgun Gothic',system-ui,sans-serif;font-size:14px;line-height:1.55}
  .wrap{max-width:1180px;margin:0 auto;padding:20px 18px 60px}
  h1{font-size:20px;margin:0}
  h2{font-size:15px;margin:22px 0 10px;padding-left:9px;border-left:4px solid var(--accent)}
  .sub{color:var(--muted);font-size:12.5px}
  .card{background:var(--card);border:1px solid var(--line);border-radius:12px;
    box-shadow:var(--shadow)}
  a{color:var(--accent);text-decoration:none}
  a:hover{text-decoration:underline}
  .up{color:var(--up)} .down{color:var(--down)} .flat{color:var(--flat)}

  /* 헤더 */
  header{display:flex;flex-wrap:wrap;justify-content:space-between;align-items:flex-end;
    gap:12px;margin-bottom:14px}
  .idxrow{display:flex;gap:12px;flex-wrap:wrap}
  .idx{padding:10px 16px;border-radius:12px;background:var(--card);border:1px solid var(--line);
    box-shadow:var(--shadow);min-width:150px}
  .idx .nm{font-size:12px;color:var(--muted)}
  .idx .val{font-size:22px;font-weight:700;letter-spacing:.3px}
  .idx .chg{font-size:13px;font-weight:600}

  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  @media(max-width:760px){.grid2{grid-template-columns:1fr}}

  .chips{display:flex;flex-wrap:wrap;gap:6px}
  .chip{background:var(--chip);border:1px solid var(--line);border-radius:999px;
    padding:3px 10px;font-size:12px}

  table{width:100%;border-collapse:collapse;font-size:13px}
  th,td{padding:8px 10px;text-align:right;border-bottom:1px solid var(--line);white-space:nowrap}
  th:first-child,td:first-child,th.l,td.l{text-align:left}
  thead th{color:var(--muted);font-weight:600;font-size:12px;background:transparent}
  tbody tr:hover{background:var(--chip)}

  .pad{padding:14px 16px}
  .issue{font-size:15px;font-weight:600;margin:4px 0;padding-left:20px;position:relative}
  .issue::before{content:"▸";position:absolute;left:2px;color:var(--accent)}
  ul.tight{margin:6px 0;padding-left:18px} ul.tight li{margin:3px 0}

  /* 장 구분 섹션 */
  .bwrap{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
  @media(max-width:900px){.bwrap{grid-template-columns:1fr}}
  .bcol h3{margin:0 0 8px;font-size:14px;display:flex;align-items:center;gap:6px}
  .bdot{width:9px;height:9px;border-radius:50%;display:inline-block}
  .d-pre{background:#f59e0b}.d-during{background:#22c55e}.d-post{background:#a855f7}
  .vid{padding:11px 13px;margin-bottom:10px}
  .vid .vt{font-weight:600;font-size:13px;margin-bottom:3px}
  .vid .vc{color:var(--muted);font-size:11.5px;margin-bottom:6px}
  .vid ul{margin:5px 0;padding-left:16px;font-size:12.5px}
  .vid li{margin:2px 0}
  .tag{display:inline-block;font-size:11px;padding:1px 7px;border-radius:6px;
    background:var(--chip);border:1px solid var(--line);margin:2px 3px 0 0}
  .tag.p{color:var(--up)} .tag.n{color:var(--down)}
  .badge{font-size:11px;padding:1px 7px;border-radius:6px;border:1px solid var(--line)}

  .empty{color:var(--muted);font-size:12.5px;padding:8px 0}
  footer{margin-top:26px;color:var(--muted);font-size:11.5px;text-align:center}
  .fnote{background:var(--chip);border:1px solid var(--line);border-radius:8px;
    padding:8px 12px;font-size:12px;color:var(--muted);margin-top:8px}
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div>
      <h1>📊 경제 유튜브 종합 대시보드</h1>
      <div class="sub">
        {{ date }} · 시장 기준일 {{ stocks.base_date }}
        {% if not stocks.is_trading_day %}<span class="badge">휴장/주말 — 직전 영업일 기준</span>{% endif %}
        · 분석 영상 {{ video_count }}개
      </div>
      <div class="sub" style="margin-top:5px">📰 <a href="report_{{ date }}.html">채널별 상세 리포트 보기 →</a></div>
    </div>
    <div class="idxrow">
      {% set k = stocks.indices.get('kospi', {}) %}
      {% set q = stocks.indices.get('kosdaq', {}) %}
      <div class="idx">
        <div class="nm">코스피 KOSPI</div>
        <div class="val {{ k.change_pct|signcls }}">{{ k.close|num }}</div>
        <div class="chg {{ k.change_pct|signcls }}">{{ k.change_pct|pct }}</div>
      </div>
      <div class="idx">
        <div class="nm">코스닥 KOSDAQ</div>
        <div class="val {{ q.change_pct|signcls }}">{{ q.close|num }}</div>
        <div class="chg {{ q.change_pct|signcls }}">{{ q.change_pct|pct }}</div>
      </div>
    </div>
  </header>

  <!-- 시총 TOP5 -->
  <div class="grid2">
    {% for mkt, label in [('kospi','코스피 시총 TOP5'), ('kosdaq','코스닥 시총 TOP5')] %}
    <div class="card pad">
      <h2 style="margin-top:0">{{ label }}</h2>
      <table>
        <thead><tr><th class="l">종목</th><th>시가총액</th><th>현재가</th><th>등락률</th></tr></thead>
        <tbody>
        {% for s in stocks.top5.get(mkt, []) %}
          <tr>
            <td class="l">{{ loop.index }}. {{ s.name }}</td>
            <td>{{ s.market_cap|won }}</td>
            <td>{{ s.price|num }}</td>
            <td class="{{ s.change_pct|signcls }}">{{ s.change_pct|pct }}</td>
          </tr>
        {% else %}
          <tr><td class="l empty" colspan="4">데이터 없음</td></tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
    {% endfor %}
  </div>

  <!-- 오늘의 핵심 -->
  <h2>🔑 오늘의 핵심</h2>
  <div class="card pad">
    {% if overall.get('핵심이슈3줄') %}
      {% for it in overall['핵심이슈3줄'] %}<div class="issue">{{ it }}</div>{% endfor %}
    {% else %}<div class="empty">분석된 핵심 이슈가 없습니다.</div>{% endif %}
    <div class="grid2" style="margin-top:12px">
      <div>
        <strong>🤝 컨센서스</strong>
        <ul class="tight">
          {% for c in overall.get('컨센서스', []) %}<li>{{ c }}</li>{% else %}<li class="empty">-</li>{% endfor %}
        </ul>
      </div>
      <div>
        <strong>⚔️ 엇갈리는 시각</strong>
        <ul class="tight">
          {% for c in overall.get('엇갈리는시각', []) %}<li>{{ c }}</li>{% else %}<li class="empty">-</li>{% endfor %}
        </ul>
      </div>
    </div>
  </div>

  <!-- 개장전/중/후 -->
  <h2>🕘 개장전 · 개장중 · 개장후</h2>
  <div class="bwrap">
    {% for b in bucket_order %}
    <div class="bcol">
      <h3><span class="bdot d-{{ b }}"></span>{{ b|blabel }} <span class="sub">({{ buckets[b]|length }})</span></h3>
      {% for v in buckets[b] %}
        <div class="card vid">
          <div class="vt"><a href="{{ v.url }}" target="_blank">{{ v.title }}</a></div>
          {% set dir = v.시장전망.방향 if v.시장전망 else '불명' %}
          <div class="vc">{{ v.channel }}
            · <span class="{{ 'up' if dir=='강세' else ('down' if dir=='약세' else '') }}">전망: {{ dir }}</span>
            {% if not v.from_subtitle %}· <span class="badge">자막없음</span>{% endif %}
          </div>
          <ul>{% for s in v.핵심요약 %}<li>{{ s }}</li>{% endfor %}</ul>
          {% if v.언급종목 %}
          <div>
            {% for m in v.언급종목 %}
              <span class="tag {{ 'p' if m.방향성=='긍정' else ('n' if m.방향성=='부정' else '') }}">{{ m.name }}{% if m.방향성 %} · {{ m.방향성 }}{% endif %}</span>
            {% endfor %}
          </div>
          {% endif %}
        </div>
      {% else %}
        <div class="empty">해당 시간대 업로드 없음</div>
      {% endfor %}
    </div>
    {% endfor %}
  </div>

  <!-- 언급 종목 테이블 -->
  <h2>📈 언급 종목 펀더멘털</h2>
  <div class="card pad">
    <table>
      <thead><tr>
        <th class="l">종목</th><th class="l">코드</th><th>시가총액</th><th>현재가</th>
        <th>등락률</th><th>영업이익</th><th>매출액</th><th>PER</th><th>PBR</th>
        <th>언급</th><th class="l">방향</th>
      </tr></thead>
      <tbody>
      {% for m in mentioned %}
        <tr>
          <td class="l">{{ m.name }}</td>
          <td class="l">{{ m.code or '-' }}</td>
          <td>{{ m.market_cap|won }}</td>
          <td>{{ m.price|num }}</td>
          <td class="{{ m.change_pct|signcls }}">{{ m.change_pct|pct }}</td>
          <td>{{ m.영업이익|eok }}</td>
          <td>{{ m.매출액|eok }}</td>
          <td>{{ m.per|num }}</td>
          <td>{{ m.pbr|num }}</td>
          <td>{{ m.mention_count }}</td>
          <td class="l {{ 'up' if m.방향성=='긍정' else ('down' if m.방향성=='부정' else '') }}">{{ m.방향성 or '-' }}</td>
        </tr>
      {% else %}
        <tr><td class="l empty" colspan="11">언급된 종목이 없습니다.</td></tr>
      {% endfor %}
      </tbody>
    </table>
    <div class="fnote">영업이익·매출액은 네이버금융 최근 연간 실적(억원), 시총·등락률은 KRX {{ stocks.base_date }} 기준.
      종목명 매핑은 자동 추정으로 오차가 있을 수 있습니다.</div>
  </div>

  <!-- 참고자료 -->
  <h2>🔗 참고자료 · 원본 영상</h2>
  <div class="card pad">
    {% set reps = overall.get('반복언급종목', []) %}
    {% if reps %}
    <div style="margin-bottom:10px">
      <strong>반복 언급 종목</strong>
      <div class="chips" style="margin-top:6px">
        {% for r in reps %}<span class="chip">{{ r.name }} ×{{ r.count }}</span>{% endfor %}
      </div>
    </div>
    {% endif %}
    <strong>원본 영상 링크</strong>
    <ul class="tight" style="margin-top:6px">
      {% for b in bucket_order %}{% for v in buckets[b] %}
        <li><span class="sub">[{{ b|blabel }}] {{ v.channel }}</span> — <a href="{{ v.url }}" target="_blank">{{ v.title }}</a></li>
      {% endfor %}{% endfor %}
    </ul>
  </div>

  <footer>자동 생성 · 매일 경제 유튜브 분석 파이프라인 · {{ date }}</footer>
</div>
</body>
</html>
